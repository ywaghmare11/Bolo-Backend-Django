# Copy to .env and fill in real values. Never commit .env.

# Django
DJANGO_SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - own fresh Postgres DB, not shared with the Node bolo-backend
DATABASE_URL=postgresql://bolo_django:CHANGE_ME@localhost:5432/bolo_django

# Auth
JWT_SECRET=
COOKIE_SECURE=False

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (evidence files)
S3_BUCKET_NAME=

# AWS SES (reminder / due-date notification emails) - IAM-role-only via the default
# boto3 credential provider chain in prod, same pattern as S3; no SMTP_* vars
SES_FROM_EMAIL=
